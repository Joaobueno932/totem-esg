# Porta da API
PORT=3001

# Conexão PostgreSQL
DATABASE_URL=postgresql://USUARIO:SENHA@HOST.sa-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Segredo do JWT (troque em produção por um valor longo e aleatório)
JWT_SECRET=troque-este-segredo-em-producao

# Expiração do token de admin
JWT_EXPIRES_IN=8h

# Origens permitidas no CORS (separadas por vírgula). Em dev pode usar *
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Rate limit da rota pública de sincronização (requisições por janela de 15 min, por IP)
SYNC_RATE_LIMIT=300

# Em produção (Netlify) defina NODE_ENV=production
# NODE_ENV=production

# Admin criado automaticamente no build do Netlify (npm run create-admin:env).
# Se não definir ADMIN_EMAIL/ADMIN_PASSWORD, o passo é apenas ignorado (não falha o build).
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Administrador
