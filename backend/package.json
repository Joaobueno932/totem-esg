{
  "name": "carbono-zero-backend",
  "version": "1.0.0",
  "description": "API do sistema Carbono Zero - totens de eventos",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "create-admin": "node scripts/create-admin.js",
    "create-admin:env": "node scripts/create-admin-env.js",
    "netlify:build": "npm run migrate && npm run seed && npm run create-admin:env",
    "test:e2e": "node scripts/e2e-test.mjs"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "serverless-http": "^3.2.0",
    "zod": "^3.23.8"
  }
}
